# ================================================
# AEGISPAY AI — Environment Variables
# ================================================
# Copy this file to .env  (setup.bat does this automatically)

# ─── APP ───────────────────────────────────────
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── JWT ────────────────────────────────────────
# Change these to any long random strings in production
JWT_SECRET=aegispay_jwt_secret_change_in_production_2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=aegispay_refresh_secret_change_in_production_2024
JWT_REFRESH_EXPIRES_IN=7d

# ─── MONGODB ────────────────────────────────────
# Local MongoDB (no cloud needed)
MONGODB_URI=mongodb://localhost:27017/aegispay

# ─── AI SERVICE ─────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=aegispay-ai-internal-key

# ─── INSURANCE ───────────────────────────────────
INSURANCE_CONTRIBUTION_RATE=0.005

# ─── RATE LIMITING ───────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── ENCRYPTION ──────────────────────────────────
ENCRYPTION_KEY=aegispay_32char_encryption_key!!

# ─── NEXT.JS FRONTEND ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=AegisPay AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── OPTIONAL: Google OAuth ──────────────────────
# Leave blank to skip Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ─── OPTIONAL: Email Notifications ───────────────
# Leave blank to skip email (use console output instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AegisPay AI <noreply@aegispay.ai>
